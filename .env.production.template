# PNG Police Cyber Crime Monitoring System - Production Environment
# Copy this file to .env in production and fill in your actual values

# Database - Neon PostgreSQL Production Database
DATABASE_URL="postgresql://username:password@hostname:5432/cyber_crime_monitoring_prod?sslmode=require"

# NextAuth.js - Production Authentication
NEXTAUTH_SECRET="production-secret-key-at-least-32-characters-long-and-random"
NEXTAUTH_URL="https://png-police-cyber-crime.netlify.app"

# Email Service - SendGrid Production
EMAIL_HOST="smtp.sendgrid.net"
EMAIL_PORT="587"
EMAIL_USER="apikey"
EMAIL_PASS="your-sendgrid-api-key-here"
EMAIL_FROM="PNG Police Cyber Crime Unit <noreply@pngpolice.gov.pg>"

# AWS S3 - Cloud Storage for Evidence Files
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="ap-southeast-2"
AWS_S3_BUCKET="png-police-cyber-evidence"
AWS_S3_EVIDENCE_PREFIX="evidence/"

# Security & Application
JWT_SECRET="another-32-character-production-secret-key"
APP_NAME="PNG Police Cyber Crime Monitoring"
APP_URL="https://png-police-cyber-crime.netlify.app"
NODE_ENV="production"

# File Upload Configuration
UPLOAD_DIR="/tmp/uploads"  # Netlify functions use /tmp
MAX_FILE_SIZE="104857600"  # 100MB for cloud storage
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"  # Optional fallback

# Integration with Main PNG Police System
MAIN_SYSTEM_API_URL="https://policemanagementsystem.vercel.app/api"
MAIN_SYSTEM_API_KEY="integration-api-key-for-main-system"
MAIN_SYSTEM_WEBHOOK_SECRET="webhook-secret-for-verification"

# Monitoring & Analytics - Sentry Error Tracking
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_PROJECT="png-police-cyber-crime"
SENTRY_ORG="png-police"

# Performance Monitoring - Vercel Analytics
VERCEL_ANALYTICS_ID="your-vercel-analytics-id"

# Search Configuration - Algolia (Optional)
ALGOLIA_APP_ID="your-algolia-app-id"
ALGOLIA_API_KEY="your-algolia-api-key"
ALGOLIA_SEARCH_API_KEY="your-algolia-search-only-key"

# Rate Limiting & Security
RATE_LIMIT_MAX="1000"  # requests per window
RATE_LIMIT_WINDOW="900000"  # 15 minutes in milliseconds
ENCRYPTION_KEY="32-character-encryption-key-for-sensitive-data"

# Backup Configuration
BACKUP_ENCRYPTION_KEY="backup-encryption-key-32-characters-long"
BACKUP_STORAGE_URL="s3://png-police-backups"
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# Health Monitoring
HEALTH_CHECK_SECRET="health-check-secret-key"
UPTIME_MONITOR_URL="https://uptime-monitor.com/webhook"

# Feature Flags
FEATURE_ADVANCED_SEARCH="true"
FEATURE_CLOUD_STORAGE="true"
FEATURE_API_DOCS="true"
FEATURE_MONITORING="true"
FEATURE_ANALYTICS="true"

# Custom Domain Configuration
CUSTOM_DOMAIN="cyber-crime.pngpolice.gov.pg"
SSL_CERT_PATH="/etc/ssl/certs"
SSL_KEY_PATH="/etc/ssl/private"

# Webhook Configuration
WEBHOOK_SECRET="webhook-signature-verification-secret"
WEBHOOK_TIMEOUT="30000"  # 30 seconds

# Cache Configuration
REDIS_URL="redis://username:password@hostname:port"
CACHE_TTL="3600"  # 1 hour default cache TTL